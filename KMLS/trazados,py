#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Genera un XML con la estructura:
 
    <!ELEMENT trazado (coordenadas+)>
    <!ELEMENT coordenadas (longitud, latitud, altitud)>
    <!ELEMENT latitud (#PCDATA)>
    <!ELEMENT longitud (#PCDATA)>
    <!ELEMENT altitud (#PCDATA)>
 
a partir del elemento <coordinates> del KML (el del recorrido, dentro de LineString).
 
Uso:
    python kml_a_trazado.py entrada.kml [salida.xml]
"""
 
import sys
import xml.etree.ElementTree as ET
from xml.dom import minidom
 
 
def extraer_coordenadas(ruta_kml):
    """Devuelve la lista de tripletas (lon, lat, alt) del LineString del KML."""
    tree = ET.parse(ruta_kml)
    root = tree.getroot()
 
    # El KML usa un namespace; lo detectamos del tag raíz: "{namespace}kml"
    ns = ""
    if root.tag.startswith("{"):
        ns = root.tag[: root.tag.index("}") + 1]
 
    # Buscamos el <coordinates> que está dentro de un <LineString> (el trazado),
    # ignorando el del <Point> (waypoint suelto).
    elem = None
    for ls in root.iter(f"{ns}LineString"):
        elem = ls.find(f"{ns}coordinates")
        if elem is not None:
            break
 
    if elem is None or not (elem.text and elem.text.strip()):
        raise ValueError("No se encontró un <coordinates> dentro de <LineString> en el KML.")
 
    coordenadas = []
    # Las coordenadas vienen separadas por espacios/saltos de línea.
    # Cada coordenada es: longitud,latitud,altitud
    for token in elem.text.split():
        partes = token.split(",")
        if len(partes) < 2:
            continue
        lon = partes[0]
        lat = partes[1]
        alt = partes[2] if len(partes) >= 3 else "0"
        coordenadas.append((lon, lat, alt))
 
    return coordenadas
 
 
def construir_xml(coordenadas):
    """Construye el árbol XML según el DTD pedido."""
    trazado = ET.Element("trazado")
    for lon, lat, alt in coordenadas:
        coord = ET.SubElement(trazado, "coordenadas")
        ET.SubElement(coord, "longitud").text = lon
        ET.SubElement(coord, "latitud").text = lat
        ET.SubElement(coord, "altitud").text = alt
    return trazado
 
 
def guardar_xml(elemento, ruta_salida):
    """Escribe el XML con indentación legible."""
    crudo = ET.tostring(elemento, encoding="utf-8")
    bonito = minidom.parseString(crudo).toprettyxml(indent="  ", encoding="UTF-8")
    with open(ruta_salida, "wb") as f:
        f.write(bonito)
 
 
def main():
    if len(sys.argv) < 2:
        print("Uso: python kml_a_trazado.py entrada.kml [salida.xml]")
        sys.exit(1)
 
    entrada = sys.argv[1]
    salida = sys.argv[2] if len(sys.argv) >= 3 else "trazado.xml"
 
    coordenadas = extraer_coordenadas(entrada)
    arbol = construir_xml(coordenadas)
    guardar_xml(arbol, salida)
 
    print(f"Generado '{salida}' con {len(coordenadas)} coordenadas.")
 
 
if __name__ == "__main__":
    main()
